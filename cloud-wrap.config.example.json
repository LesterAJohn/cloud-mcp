{
  "vault": {
    "module": "",
    "options": {}
  },
  "providers": {
    "aws": {
      "command": "aws",
      "env": {
        "AWS_REGION": "us-east-1"
      },
      "defaultProfile": "default",
      "profileSupport": {
        "mode": "env",
        "envVar": "AWS_PROFILE"
      },
      "profiles": {
        "default": {
          "env": {
            "AWS_PROFILE": "default"
          },
          "users": []
        }
      }
    },
    "gcp": {
      "command": "gcloud",
      "env": {
        "CLOUDSDK_CORE_PROJECT": "my-project"
      },
      "defaultProfile": "default",
      "profileSupport": {
        "mode": "env",
        "envVar": "CLOUDSDK_ACTIVE_CONFIG_NAME"
      },
      "profiles": {
        "default": {
          "env": {
            "CLOUDSDK_ACTIVE_CONFIG_NAME": "default"
          },
          "users": []
        }
      }
    },
    "azure": {
      "command": "az",
      "env": {
        "AZURE_CONFIG_DIR": "/tmp/azure-config"
      }
    },
    "oci": {
      "command": "oci",
      "env": {
        "OCI_CLI_CONFIG_FILE": "/home/user/.oci/config"
      },
      "defaultProfile": "DEFAULT",
      "profileSupport": {
        "mode": "env",
        "envVar": "OCI_CLI_PROFILE"
      },
      "profiles": {
        "DEFAULT": {
          "env": {
            "OCI_CLI_PROFILE": "DEFAULT"
          },
          "users": []
        }
      }
    },
    "alibaba": {
      "command": "aliyun",
      "env": {},
      "profileSupport": {
        "mode": "arg",
        "flag": "--profile"
      },
      "profiles": {
        "prod": {
          "args": ["--region", "cn-hangzhou"],
          "users": ["platform-admin", "secops"]
        }
      }
    },
    "digitalocean": {
      "command": "doctl",
      "env": {},
      "profileSupport": {
        "mode": "arg",
        "flag": "--context"
      }
    },
    "ibmcloud": {
      "command": "ibmcloud",
      "env": {}
    },
    "tencent": {
      "command": "tccli",
      "env": {},
      "profileSupport": {
        "mode": "arg",
        "flag": "--profile"
      }
    },
    "huawei": {
      "command": "hcloud",
      "env": {}
    }
  }
}
